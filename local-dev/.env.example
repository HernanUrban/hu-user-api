# Credenciales de Grafana Cloud para Alloy
# Obtenerlas en: Grafana Cloud > Connections > Collector setup > OpenTelemetry
#
# GRAFANA_CLOUD_OTLP_ENDPOINT  → copiar el valor de OTEL_EXPORTER_OTLP_ENDPOINT
#
# GRAFANA_CLOUD_OTLP_AUTH_HEADER → extraer de OTEL_EXPORTER_OTLP_HEADERS:
#   El valor tiene formato:  Authorization=Basic%20<base64>
#   Quitar "Authorization=" y reemplazar "%20" por un espacio:
#   Resultado:               Basic <base64>

GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
GRAFANA_CLOUD_OTLP_AUTH_HEADER=Basic <pegar_el_valor_base64_aqui>
